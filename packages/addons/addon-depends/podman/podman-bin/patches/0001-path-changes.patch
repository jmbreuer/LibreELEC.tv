From 79562db355cfedba14af84aa204f16015dbbb403 Mon Sep 17 00:00:00 2001
From: Rudi Heitbaum <rudi@heitbaum.com>
Date: Sun, 05 Feb 2023 09:36:17 +0000
Subject: [PATCH] path changes

diff --git a/pkg/rootless/rootless_linux.c b/pkg/rootless/rootless_linux.c
index 1054c3218..ffe6f5861 100644
--- a/pkg/rootless/rootless_linux.c
+++ b/pkg/rootless/rootless_linux.c
@@ -23,8 +23,8 @@
 #include <sys/file.h>
 #include <stdio.h>
 
-#define ETC_PREEXEC_HOOKS "/etc/containers/pre-exec-hooks"
-#define LIBEXECPODMAN "/usr/libexec/podman"
+#define ETC_PREEXEC_HOOKS "/storage/.kodi/addons/service.system.podman/etc/containers/pre-exec-hooks"
+#define LIBEXECPODMAN "/storage/.kodi/addons/service.system.podman/libexec"
 
 #ifndef FD_NSFS_ROOT
 /* Copied from /usr/include/linux/fcntl.h.  */
diff --git a/vendor/go.podman.io/common/pkg/config/config_linux.go b/vendor/go.podman.io/common/pkg/config/config_linux.go
index e0b4672e7..f7fec8d6a 100644
--- a/vendor/go.podman.io/common/pkg/config/config_linux.go
+++ b/vendor/go.podman.io/common/pkg/config/config_linux.go
@@ -5,10 +5,7 @@ import (
 )
 
 var defaultHelperBinariesDir = []string{
-	"/usr/local/libexec/podman",
-	"/usr/local/lib/podman",
-	"/usr/libexec/podman",
-	"/usr/lib/podman",
+	"/storage/.kodi/addons/service.system.podman/bin",
 }
 
 // Capabilities returns the capabilities parses the Add and Drop capability
