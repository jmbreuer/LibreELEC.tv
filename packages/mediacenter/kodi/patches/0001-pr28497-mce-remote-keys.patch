From b856cd8f8a213c52771bb39aaeb831614973716c Mon Sep 17 00:00:00 2001
From: Matthias Reichl <hias@horus.com>
Date: Fri, 26 Jun 2026 14:39:37 +0200
Subject: [PATCH 05/12] [linux][keyboard] Add support for mapping evdev codes
 to keys

xkb doesn't map several keycodes that are used on lots of remotes
and it also doesn't look like it will support them in the near future.

Add a mapping table from evdev codes to kodi keycodes that can
be used as a fallback.

Also include mappings for the xkb keysyms defined in XkbCompat.h
so those keys will also work on Linux systems with (a bit) older
xkb / xkeyboard-config versions.

Signed-off-by: Matthias Reichl <hias@horus.com>
---
 xbmc/platform/linux/input/CMakeLists.txt      |  9 +++-
 xbmc/platform/linux/input/EvdevKeyMapping.cpp | 42 +++++++++++++++++++
 xbmc/platform/linux/input/EvdevKeyMapping.h   | 18 ++++++++
 3 files changed, 67 insertions(+), 2 deletions(-)
 create mode 100644 xbmc/platform/linux/input/EvdevKeyMapping.cpp
 create mode 100644 xbmc/platform/linux/input/EvdevKeyMapping.h

diff --git a/xbmc/platform/linux/input/CMakeLists.txt b/xbmc/platform/linux/input/CMakeLists.txt
index 2b71f4245b68..32b7ce4987b2 100644
--- a/xbmc/platform/linux/input/CMakeLists.txt
+++ b/xbmc/platform/linux/input/CMakeLists.txt
@@ -18,11 +18,16 @@ if("gbm" IN_LIST CORE_PLATFORM_NAME_LC)
                         LibInputKeyboard.h
                         LibInputPointer.h
                         LibInputSettings.h
-                        LibInputTouch.h
-                        XkbCompat.h)
+                        LibInputTouch.h)
   endif()
 endif()
 
+if(("gbm" IN_LIST CORE_PLATFORM_NAME_LC AND TARGET ${APP_NAME_LC}::LibInput) OR "wayland" IN_LIST CORE_PLATFORM_NAME_LC)
+  list(APPEND SOURCES EvdevKeyMapping.cpp)
+  list(APPEND HEADERS EvdevKeyMapping.h
+                      XkbCompat.h)
+endif()
+
 if(SOURCES)
   core_add_library(input_linux)
 endif()
diff --git a/xbmc/platform/linux/input/EvdevKeyMapping.cpp b/xbmc/platform/linux/input/EvdevKeyMapping.cpp
new file mode 100644
index 000000000000..102d1f49e197
--- /dev/null
+++ b/xbmc/platform/linux/input/EvdevKeyMapping.cpp
@@ -0,0 +1,42 @@
+/*
+ *  Copyright (C) 2026 Team Kodi
+ *  This file is part of Kodi - https://kodi.tv
+ *
+ *  SPDX-License-Identifier: GPL-2.0-or-later
+ *  See LICENSES/README.md for more information.
+ */
+
+#include "EvdevKeyMapping.h"
+
+#include "utils/Map.h"
+
+#include <linux/input.h>
+
+constexpr auto evdevMap = make_map<uint32_t, XBMCKey>({
+    // still missing in libxkbcommon 1.13.2
+    {KEY_PREVIOUS, XBMCK_PREVIOUS},
+    {KEY_NEXT, XBMCK_NEXT},
+    {KEY_POWER2, XBMCK_POWER2},
+    {KEY_SETUP, XBMCK_SETUP},
+    {KEY_LAST, XBMCK_RECALL_LAST},
+    {KEY_LIST, XBMCK_LIST},
+
+    // added in libxkbcommon 1.11.0 - see also XkbCompat.h
+    {KEY_OK, XBMCK_OK}, // XKB_KEY_XF86OK
+    {KEY_EPG, XBMCK_EPG}, // XKB_KEY_XF86MediaSelectProgramGuide
+    {KEY_PROGRAM, XBMCK_EPG}, // XKB_KEY_XF86MediaSelectProgramGuide
+    {KEY_PVR, XBMCK_PVR}, // XKB_KEY_XF86MediaSelectHome
+    {KEY_LANGUAGE, XBMCK_LANGUAGE}, // XKB_KEY_XF86MediaLanguageMenu
+    {KEY_TITLE, XBMCK_TITLE_MENU}, // XKB_KEY_XF86MediaTitleMenu
+    {KEY_MODE, XBMCK_AUDIO_MODE}, // XKB_KEY_XF86AudioChannelMode
+    {KEY_TV, XBMCK_TV}, // XKB_KEY_XF86MediaSelectTV
+    {KEY_RADIO, XBMCK_RADIO}, // XKB_KEY_XF86MediaSelectRadio
+    {KEY_TUNER, XBMCK_TUNER}, // XKB_KEY_XF86MediaSelectTuner
+    {KEY_PLAYER, XBMCK_LAUNCH_MEDIA_SELECT}, // XKB_KEY_XF86MediaPlayer
+    {KEY_TEXT, XBMCK_TEXT} // XKB_KEY_XF86MediaSelectTeletext
+});
+
+std::optional<XBMCKey> CEvdevKeyMapping::XBMCKeyForEvdevCode(uint32_t code)
+{
+  return evdevMap.get(code);
+}
diff --git a/xbmc/platform/linux/input/EvdevKeyMapping.h b/xbmc/platform/linux/input/EvdevKeyMapping.h
new file mode 100644
index 000000000000..022a15625d95
--- /dev/null
+++ b/xbmc/platform/linux/input/EvdevKeyMapping.h
@@ -0,0 +1,18 @@
+/*
+ *  Copyright (C) 2026 Team Kodi
+ *  This file is part of Kodi - https://kodi.tv
+ *
+ *  SPDX-License-Identifier: GPL-2.0-or-later
+ *  See LICENSES/README.md for more information.
+ */
+
+#include "input/keyboard/XBMC_keysym.h"
+
+#include <cstdint>
+#include <optional>
+
+class CEvdevKeyMapping
+{
+public:
+  static std::optional<XBMCKey> XBMCKeyForEvdevCode(uint32_t code);
+};
